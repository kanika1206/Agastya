    var page = 1;
    var loading = false;
    var $loadMoreButton = $('.load-more-button');
    var $postContainer = $('.posts-container');
    var categoryID = 5240;
    var postsPerPage = "12";

    // Function to check if "Load More" button should be shown
    function showLoadMoreButton() {
        var postCount = $postContainer.find('.post').length;
        if (postCount < postsPerPage) {
            $loadMoreButton.hide();
        } else {
            $loadMoreButton.show();
        }
    }

    showLoadMoreButton(); // Initial check on page load

    $loadMoreButton.on('click', function() {
        if (!loading) {
            loading = true;
            page++;
            $.ajax({
                url: ajaxloadmore.ajaxurl,
                type: 'post',
                data: {
                    action: 'load_more_posts',
                    page: page,
                    category_id: categoryID,
                    nonce: ajaxloadmore.nonce
                },
                success: function(response) {
                    if (response.trim() !== '') {
                        $postContainer.append(response);
                        showLoadMoreButton(); // Check if "Load More" button should be shown
                    } else {
                        $loadMoreButton.hide();
                        $('<p class="no-more-message fs-20 fw-600">No more articles to load.</p>').insertBefore($loadMoreButton);
                    }
                    loading = false;
                }
            });
        }
    });
});</script> <footer id="site-footer" class="site-footer"><div class="footer-main color-white py30"><div class="container"><div class="grid tb-columns-2 footer-top-grid align-items-center grid-gap-20"><div class=" footer-logo mb-align-center"> <img class="alignnone size-full wp-image-1007" src="https://hyderabadmail.com/wp-content/uploads/2024/03/hyderabad-mail-logo-footer.png" alt="Hyderabad Mail Logo Footer" width="542" height="92" /></div><div class="footer-social-links social-links align-right mb-align-center"><a href="https://www.facebook.com/HyderabadMail/" class="facebook social-icon" rel="noopener nofollow" aria-label="Facebook" target="_blank"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 264 512"><path d="M215.8 85H264V3.6C255.7 2.5 227.1 0 193.8 0 124.3 0 76.7 42.4 76.7 120.3V192H0v91h76.7v229h94V283h73.6l11.7-91h-85.3v-62.7c0-26.3 7.3-44.3 45.1-44.3z"/></svg></a><a href="https://twitter.com/Hyderabad_Mail" class="twitter social-icon" rel="noopener nofollow" aria-label="Twitter" target="_blank"><svg viewBox="0 0 24 24" aria-hidden="true" class="r-18jsvk2 r-4qtqp9 r-yyyyoo r-rxcuwo r-1777fci r-m327ed r-dnmrzs r-494qqr r-bnwqim r-1plcrui r-lrvibr"><g><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></g></svg></a><a href="https://www.instagram.com/hyderabadmail/" class="instagram social-icon" rel="noopener nofollow" aria-label="Instagram" target="_blank"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-9