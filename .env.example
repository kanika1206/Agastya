# AGASTYA — environment variables (copy to .env and fill in)

# HMAC signing key for tamper-evident evidence credentials. REQUIRED.
# Generate a strong random value for production, e.g.: openssl rand -hex 32
AGASTYA_SIGNING_KEY=replace-with-a-strong-random-secret

# Comma-separated allowed CORS origins for the API.
AGASTYA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SQLite evidence store path (optional; defaults to agastya_violations.db).
AGASTYA_STORE_PATH=agastya_violations.db
